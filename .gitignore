# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/
ENV/
.venv/

# Flask instance folder (contains config, db, etc.)
instance/

# Environment variables (VERY IMPORTANT)
.env
.env.*

# Database files
*.db
*.sqlite3

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo

# Local utility scripts
create_db.py

# Uploaded files
src/static/uploads/*
!src/static/uploads/.gitkeep

# PyCharm
*.iml

# Testing / coverage
.coverage
htmlcov/
.pytest_cache/

# Distribution / packaging
build/
dist/
*.egg-info/

# Migrations (optional - depends if you want to track them)
migrations/__pycache__/
